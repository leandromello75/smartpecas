# =============================================================================
# SmartPeças ERP - .gitignore
# =============================================================================
# Cobre: NestJS, Prisma, Node.js, Docker, Railway, editores
# =============================================================================

# -----------------------------------------------------------------------------
# Dependências — NUNCA devem ir para o Git
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Artefatos de Build e Compilação — gerados automaticamente
# -----------------------------------------------------------------------------
dist/
build/
/packages/backend/dist/
/packages/web/dist/
/packages/web/build/

# -----------------------------------------------------------------------------
# Variáveis de Ambiente e Segredos — CRÍTICO PARA SEGURANÇA
# O arquivo .env NUNCA deve ir para o repositório.
# Use o .env.example para documentar as variáveis necessárias.
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
# Mantém apenas o arquivo de exemplo (sem valores reais)
!.env.example
!.env-example

# -----------------------------------------------------------------------------
# Prisma — cliente gerado (recriado via `prisma generate`)
# -----------------------------------------------------------------------------
/node_modules/.prisma/
/packages/backend/src/generated/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Cache de ferramentas
# -----------------------------------------------------------------------------
.npm
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Cobertura de testes
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# Docker — arquivos locais que não devem ir para o repositório
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Sistema Operacional
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editores e IDEs
# -----------------------------------------------------------------------------
.idea/
*.sublime-project
*.sublime-workspace

# VSCode: ignora tudo exceto configurações compartilhadas do projeto
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Railway — arquivos locais de CLI (se usar Railway CLI)
# -----------------------------------------------------------------------------
.railway/